PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
# Comma-separated list of additional allowed frontend origins (production domains, etc.)
# Example: CORS_ORIGINS=https://managment.wegoconnect.net,https://app.wegoconnect.net
# Note: the server also includes a small built-in default allowlist (localhost + managment.wegoconnect.net).
CORS_ORIGINS=
DB_PATH=./data/db.sqlite
MONGODB_URI=
MONGODB_DB=wegomanage
STORAGE=mongo

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=wegoconnect.noreply@gmail.com
SMTP_PASS=
MAIL_FROM="WegoConnect <wegoconnect.noreply@gmail.com>"

# Email automation (alerts digest)
ENABLE_EMAIL_AUTOMATION=false
NOTIFY_INTERVAL_MIN=15

# Used for email CTA button (optional)
APP_URL=http://localhost:5173

ADMIN_EMAIL=admin@acme.com
ADMIN_PASSWORD=change_me


